# Server
PORT=4500
NODE_ENV=production

# Security — IMPORTANT: Generate a random secret!
# Run: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=change-me-to-a-random-string

# Encryption key for secrets stored in DB (optional, falls back to JWT_SECRET)
# Run: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=

# CORS — comma-separated allowed origins (only enforced when NODE_ENV=production)
ALLOWED_ORIGINS=https://your-domain.com

# AMI (Asterisk Manager Interface)
AMI_HOST=62.210.59.81
AMI_PORT=5100
AMI_USER=webrtcc
AMI_PASSWORD=
